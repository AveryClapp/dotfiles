#!/usr/bin/env bash
set -euo pipefail

TARGET="${1:-}"
LINES="${2:-200}"

if [[ "$TARGET" == -h || "$TARGET" == --help || -z "$TARGET" ]]; then
  printf 'Usage: agent-capture <pane-id> [lines]\n'
  [[ -n "$TARGET" ]] && exit 0 || exit 2
fi
[[ "$TARGET" == %* ]] || { printf 'error: pane ID must look like %%42\n' >&2; exit 2; }
[[ "$LINES" =~ ^[1-9][0-9]*$ ]] || { printf 'error: lines must be a positive integer\n' >&2; exit 2; }

tmux capture-pane -p -t "$TARGET" -S "-$LINES"
