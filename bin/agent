#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent <command> [options]

Commands:
  init       Initialize the current repository for agent workflows.
  new        Launch an isolated agent worktree.
  send       Send literal text to a tmux pane.
  capture    Capture recent output from a tmux pane.
  status     Show active worktrees and agents.
  dashboard Open the workmux agent dashboard.
  check      Run the repository verification contract.
  review     Launch an independent review worktree.
  land       Verify and explicitly land an agent branch.
  gc         Remove merged or stale agent worktrees.
  doctor     Validate the installed agent environment.
  help       Show this help.

The hyphenated commands such as agent-doctor remain available.
EOF
}

command_name="${1:-help}"
[[ $# -eq 0 ]] || shift

case "$command_name" in
  help|-h|--help)
    usage
    ;;
  dashboard)
    exec agent-status --dashboard "$@"
    ;;
  init|new|send|capture|status|check|review|land|gc|doctor)
    exec "agent-$command_name" "$@"
    ;;
  *)
    printf 'error: unknown agent command: %s\n\n' "$command_name" >&2
    usage >&2
    exit 2
    ;;
esac
