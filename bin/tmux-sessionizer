#!/usr/bin/env bash
# Switch between active tmux sessions, or create a new one from a project dir.
# Bind to prefix+f in tmux.conf.
#   default view : pick an active session (Enter switches to it)
#   ctrl-f       : search project dirs to create/switch a new session

switch_to() {
    if [[ -z "$TMUX" ]]; then
        tmux attach-session -t "$1"
    else
        tmux switch-client -t "$1"
    fi
}

new_from_dir() {
    local selected session
    selected=$(find \
        ~/Documents/Coding/GitProjects \
        ~/Documents/Coding \
        -mindepth 1 -maxdepth 1 -type d \
        2>/dev/null | sort -u | fzf --prompt="new session: " --height=40%)

    [[ -z "$selected" ]] && exit 0

    session=$(basename "$selected" | tr '[:upper:]' '[:lower:]' | tr ' .' '_')

    if ! tmux has-session -t="$session" 2>/dev/null; then
        tmux new-session -ds "$session" -c "$selected"
    fi

    switch_to "$session"
}

sessions=$(tmux list-sessions -F '#S' 2>/dev/null)

# No sessions yet: skip straight to creating one.
if [[ -z "$sessions" ]]; then
    new_from_dir
    exit 0
fi

result=$(printf '%s\n' "$sessions" | fzf \
    --prompt="session: " \
    --height=40% \
    --header="ctrl-f: new from dir" \
    --expect=ctrl-f)

key=$(head -1 <<< "$result")
selected=$(sed -n 2p <<< "$result")

if [[ "$key" == "ctrl-f" ]]; then
    new_from_dir
elif [[ -n "$selected" ]]; then
    switch_to "$selected"
fi
